rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: clients
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - niche: string (optional)
    //   - logo: string (optional)
    //   - platforms: list (optional)
    //   - investmentValue: number (optional)
    //   - platformInvestments: map (optional)
    //   - status: string (optional, enum: active, inactive)
    //   - country: string (optional)
    //   - currency: string (optional)
    //   - createdAt: timestamp (required)
    //   - uid: string (required, matches owner)
    //
    // Collection: histories
    // Document ID: auto-generated
    // Fields:
    //   - clientId: string (required)
    //   - mode: string (required, enum)
    //   - content: string (required, max 50000 chars)
    //   - createdAt: timestamp (required)
    //   - uid: string (required, matches owner)
    //
    // Collection: sales_analyses
    // Document ID: auto-generated
    // Fields:
    //   - clientId: string (required)
    //   - niche: string (required)
    //   - createdAt: timestamp (required)
    //   - uid: string (required, matches owner)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && resource != null && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "gabriel@gdtmidias.com" && request.auth.token.email_verified == true);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('niche' in data) || data.niche == null || (data.niche is string && data.niche.size() <= 200)) &&
             (!('logo' in data) || data.logo == null || (data.logo is string && data.logo.size() <= 1000000)) &&
             (!('platforms' in data) || data.platforms == null || (data.platforms is list)) &&
             (!('investmentValue' in data) || data.investmentValue == null || (data.investmentValue is number)) &&
             (!('platformInvestments' in data) || data.platformInvestments == null || (data.platformInvestments is map)) &&
             (!('status' in data) || data.status == null || (data.status in ['active', 'inactive'])) &&
             (!('country' in data) || data.country == null || (data.country is string && data.country.size() <= 100)) &&
             (!('currency' in data) || data.currency == null || (data.currency is string && data.currency.size() <= 10)) &&
             data.createdAt is timestamp &&
             data.uid is string;
    }

    function isValidHistory(data) {
      return data.clientId is string &&
             data.mode in ['communication', 'account_actions', 'group_update', 'client_response', 'meeting_summary', 'sales_analyzer', 'ad_copy_generator', 'tasks'] &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.createdAt is timestamp &&
             data.uid is string;
    }

    function isValidSalesAnalysis(data) {
      return data.clientId is string &&
             data.niche is string && data.niche.size() > 0 && data.niche.size() <= 200 &&
             data.createdAt is timestamp &&
             data.uid is string;
    }

    function isValidTask(data) {
      return data.clientId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 2000)) &&
             data.deadline is timestamp &&
             data.priority in ['low', 'medium', 'high'] &&
             data.status in ['pending', 'completed', 'overdue'] &&
             (!('recurrence' in data) || data.recurrence == null || (
               data.recurrence is map &&
               data.recurrence.type in ['none', 'daily', 'weekly', 'monthly'] &&
               (!('days' in data.recurrence) || data.recurrence.days is list)
             )) &&
             data.createdAt is timestamp &&
             (!('completedAt' in data) || data.completedAt == null || data.completedAt is timestamp) &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Test connection path
    match /test/connection {
      allow read: if isAuthenticated();
    }

    match /clients/{clientId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidClient(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidClient(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /histories/{historyId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidHistory(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidHistory(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /sales_analyses/{analysisId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSalesAnalysis(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidSalesAnalysis(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
